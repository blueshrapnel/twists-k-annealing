@article{Marzen2017,
  abstract = {In complex environments, there are costs to both ignorance and
              perception. An organism needs to track fitness-relevant information
              about its world, but the more information it tracks, the more
              resources it must devote to memory and processing. Rate-distortion
              theory shows that, when errors are allowed, remarkably efficient
              internal representations can be found by biologically-plausible
              hill-climbing mechanisms. We identify two regimes: a high-fidelity
              regime where perceptual costs scale logarithmically with
              environmental complexity, and a low-fidelity regime where
              perceptual costs are, remarkably, independent of the environment.
              When environmental complexity is rising, Darwinian evolution should
              drive organisms to the threshold between the high- and low-fidelity
              regimes. Organisms that code efficiently will find themselves able
              to make, just barely, the most subtle distinctions in their
              environment.},
  author = {Marzen, Sarah E and Dedeo, Simon},
  doi = {10.1098/rsif.2017.0166},
  file = {:Users/karen/Library/Application Support/Mendeley
          Desktop/Downloaded/Marzen, Dedeo - 2017 - The evolution of lossy
          compression.pdf:pdf},
  journal = {Journal of the Royal Society Interface},
  keywords = {Information Theory,Rate Distortion,biomathematics,computational
              biology},
  number = {130},
  title = {{The evolution of lossy compression}},
  url = {https://royalsocietypublishing.org/doi/10.1098/rsif.2017.0166
         https://arxiv.org/pdf/1506.06138.pdf http://tuvalu.santafe.edu/{~}
         simon/styled-13/},
  volume = {14},
  year = {2017},
}

